@import "tailwindcss";

@theme {
  --color-background: var(--bg-color);
  --color-foreground: var(--fg-color);
  --color-card: var(--card-color);
  --color-surface: var(--surface-color);
  --color-border: var(--border-color);
  --color-primary: var(--primary-color);
  --color-primary-hover: var(--primary-hover-color);
  --color-muted: var(--muted-color);
  --color-badge: var(--badge-color);
  --color-background-secondary: var(--bg-secondary-color);
  --color-danger: var(--danger-color);
  --color-success: var(--success-color);

  --font-sans: 'Inter', 'Outfit', system-ui, sans-serif;
  --font-serif: 'Georgia', 'Times New Roman', serif;
  --font-mono: 'JetBrains Mono', 'Fira Code', monospace;

  --animate-fade-in: fade-in 0.3s ease-out forwards;
  --animate-slide-up: slide-up 0.35s ease-out forwards;
  --animate-slide-down: slide-down 0.25s ease-out forwards;
  --animate-scale-in: scale-in 0.2s ease-out forwards;
  --animate-shimmer: shimmer 1.5s ease-in-out infinite;
  --animate-pulse-dot: pulse-dot 1s ease-in-out infinite;
}

:root {
  --bg-color: #faf9f7;
  --bg-secondary-color: #f3f1ed;
  --fg-color: #1c1917;
  --muted-color: #78716c;
  --card-color: #ffffff;
  --surface-color: #f5f3f0;
  --border-color: #e7e5e4;
  --primary-color: #f97316;
  --primary-hover-color: #ea580c;
  --badge-color: #f0ebe4;
  --danger-color: #ef4444;
  --success-color: #16a34a;
}

.dark {
  --bg-color: #05050a;
  --bg-secondary-color: #0d0d14;
  --fg-color: #f8fafc;
  --muted-color: #94a3b8;
  --card-color: #0f111a;
  --surface-color: #161821;
  --border-color: #1e2230;
  --primary-color: #fb923c;
  --primary-hover-color: #f97316;
  --badge-color: #161821;
  --danger-color: #f87171;
  --success-color: #4ade80;
}

/* ── Keyframes ── */
@keyframes fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slide-up {
  from { opacity: 0; transform: translateY(12px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes slide-down {
  from { opacity: 0; transform: translateY(-8px); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scale-in {
  from { opacity: 0; transform: scale(0.95); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

@keyframes pulse-dot {
  0%, 100% { opacity: 0.3; transform: scale(0.8); }
  50% { opacity: 1; transform: scale(1.1); }
}

@keyframes cm-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ── Base ── */
* {
  box-sizing: border-box;
}

body {
  margin: 0;
  padding: 0;
}

/* ── Skeleton loading ── */
.skeleton {
  background: linear-gradient(
    90deg,
    var(--badge-color) 25%,
    var(--surface-color) 50%,
    var(--badge-color) 75%
  );
  background-size: 200% 100%;
  animation: shimmer 1.5s ease-in-out infinite;
  border-radius: 6px;
}

/* ── Glassmorphism ── */
.glass {
  background: color-mix(in srgb, var(--card-color) 80%, transparent);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.glass-panel {
  background: color-mix(in srgb, var(--card-color) 60%, transparent);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid color-mix(in srgb, var(--fg-color) 8%, transparent);
  box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
}

.glow-border {
  position: relative;
}
.glow-border::before {
  content: "";
  position: absolute;
  inset: -1px;
  border-radius: inherit;
  padding: 1px;
  background: linear-gradient(to bottom right, var(--primary-color), transparent, var(--primary-color));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  opacity: 0;
  transition: opacity 0.3s ease;
  pointer-events: none;
}
.glow-border:hover::before {
  opacity: 0.5;
}

/* ── Focus rings ── */
.focus-ring {
  outline: none;
}
.focus-ring:focus-visible {
  outline: 2px solid var(--primary-color);
  outline-offset: 2px;
  border-radius: 4px;
}

/* ── Liveblocks overlay suppression ── */
[data-liveblocks-portal],
[data-liveblocks-overlay],
.__liveblocks_overlay__,
[class*="liveblocks-"]:not([class*="liveblocks-provider"]),
.lb-root,
.lb-portal,
.lb-branding,
[href*="liveblocks.io"],
img[alt*="liveblocks"],
div[class*="branding"],
div[id*="branding"] {
  display: none !important;
  visibility: hidden !important;
  opacity: 0 !important;
  pointer-events: none !important;
}

/* ── CodeMirror ── */
.cm-editor {
  height: 100%;
  font-size: 14px;
  font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
}

.cm-editor.cm-focused {
  outline: none;
}

.cm-scroller {
  padding: 16px 0;
  font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace !important;
}

.cm-line {
  padding: 0 24px;
}

.cm-gutters {
  border-right: 1px solid var(--border-color);
  background: transparent;
  color: #c8c4be;
  font-size: 12px;
}

.dark .cm-gutters {
  border-right: 1px solid #2a2a2a;
  color: #444;
}

/* ── Scrollbar ── */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: var(--border-color);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: var(--muted-color);
}

/* ── Selection ── */
::selection {
  background: #f9731633;
  color: inherit;
}

/* ── Transitions ── */
a, button {
  transition: all 0.15s ease;
}

/* ── Print styles ── */
@media print {
  @page {
    size: A4;
    margin: 1.5cm 2cm;
  }

  html, body {
    background: #fff !important;
    color: #000 !important;
  }

  nav,
  header,
  button,
  [data-no-print],
  [class*="toolbar"],
  .cm-editor,
  .cm-scroller,
  .cm-content,
  .cm-gutters,
  .cm-line,
  [class*="status"],
  [data-liveblocks-portal],
  [data-liveblocks-overlay],
  [class*="liveblocks"],
  [class*="lb-"],
  a[href*="liveblocks.io"] {
    display: none !important;
  }

  .preview-content {
    display: block !important;
    position: static !important;
    flex: none !important;
    width: 100% !important;
    max-width: 100% !important;
    height: auto !important;
    overflow: visible !important;
    border: none !important;
    padding: 0 !important;
    margin: 0 !important;
    font-family: 'Georgia', 'Times New Roman', serif !important;
    font-size: 11pt !important;
    line-height: 1.7 !important;
    color: #000 !important;
    background: #fff !important;
  }

  .preview-content h1 {
    font-size: 20pt !important;
    font-weight: 600 !important;
    margin-bottom: 12pt !important;
    border-bottom: 1px solid #ccc;
    padding-bottom: 6pt;
    page-break-after: avoid;
  }

  .preview-content h2 {
    font-size: 16pt !important;
    font-weight: 600 !important;
    margin-top: 16pt !important;
    margin-bottom: 8pt !important;
    page-break-after: avoid;
  }

  .preview-content h3 {
    font-size: 13pt !important;
    font-weight: 600 !important;
    margin-top: 12pt !important;
    page-break-after: avoid;
  }

  .preview-content p {
    margin-bottom: 8pt !important;
    orphans: 3;
    widows: 3;
  }

  .preview-content code {
    font-family: 'Courier New', monospace !important;
    font-size: 9pt !important;
    background: #f5f5f5 !important;
    padding: 1pt 4pt !important;
    border-radius: 2pt;
  }

  .preview-content pre {
    background: #f5f5f5 !important;
    border: 1px solid #ddd !important;
    padding: 10pt !important;
    border-radius: 4pt !important;
    font-size: 9pt !important;
    page-break-inside: avoid;
    overflow: visible !important;
    white-space: pre-wrap !important;
  }

  .preview-content pre code {
    background: none !important;
    padding: 0 !important;
  }

  .preview-content blockquote {
    border-left: 3pt solid #999 !important;
    padding-left: 12pt !important;
    color: #555 !important;
    margin: 8pt 0 !important;
    font-style: italic;
  }

  .preview-content ul,
  .preview-content ol {
    padding-left: 20pt !important;
    margin-bottom: 8pt !important;
  }

  .preview-content li {
    margin-bottom: 3pt !important;
  }

  .preview-content table {
    width: 100% !important;
    border-collapse: collapse !important;
    margin-bottom: 12pt !important;
    page-break-inside: avoid;
  }

  .preview-content th,
  .preview-content td {
    border: 1px solid #ccc !important;
    padding: 6pt 8pt !important;
    text-align: left !important;
    font-size: 10pt !important;
  }

  .preview-content th {
    background: #f0f0f0 !important;
    font-weight: 600 !important;
  }

  .preview-content hr {
    border: none !important;
    border-top: 1px solid #ccc !important;
    margin: 16pt 0 !important;
  }

  .preview-content a {
    color: #000 !important;
    text-decoration: underline !important;
  }

  .preview-content h1,
  .preview-content h2,
  .preview-content h3,
  .preview-content pre,
  .preview-content table,
  .preview-content blockquote {
    page-break-inside: avoid;
  }
}
/* -- Editor Clean Mode -- */
.cm-formatting {
  opacity: 0 !important;
  display: inline-block;
  width: 0;
  overflow: hidden;
  transition: all 0.2s;
}

.cm-activeLine .cm-formatting,
.cm-line:hover .cm-formatting {
  opacity: 0.4 !important;
  width: auto;
  margin: 0 2px;
}

/* -- Ultra Clean Markdown Mode -- */
.cm-formatting-strong, .cm-formatting-em, .cm-formatting-header {
  font-size: 0 !important;
  letter-spacing: -1.2ch !important;
  opacity: 0 !important;
  display: inline-block !important;
  width: 0 !important;
  pointer-events: none !important;
  transition: all 0.2s;
}

.cm-activeLine .cm-formatting-strong, 
.cm-activeLine .cm-formatting-em,
.cm-activeLine .cm-formatting-header {
  font-size: inherit !important;
  letter-spacing: normal !important;
  opacity: 0.3 !important;
  width: auto !important;
  pointer-events: auto !important;
}
